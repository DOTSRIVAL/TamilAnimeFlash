rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ---------------------------------------------------------
    // HELPERS
    // ---------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.firebase.sign_in_provider == 'anonymous');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email != null && request.auth.token.email == 'dnbdotsrival@gmail.com';
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ---------------------------------------------------------
    // DEFAULT DENY
    // ---------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // ---------------------------------------------------------
    // COLLECTIONS
    // ---------------------------------------------------------

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['avatar', 'username', 'displayName', 'updatedAt', 'totalWatchTimeSeconds']);
    }

    match /studios/{studioId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /anime/{animeId} {
      allow read: if true;
      allow update: if isAdmin() || (incoming().diff(existing()).affectedKeys().hasOnly(['viewCount']));
      allow write: if isAdmin(); 
      
      match /viewers/{userId} {
        allow read: if true;
        allow write: if (isSignedIn() && request.auth.uid == userId) || userId.matches('^guest_.*');
      }

      match /subscribers/{userId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    match /users/{userId}/bookmarks/{animeId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    match /users/{userId}/notifications/{notificationId} {
      allow read: if isOwner(userId);
      allow write: if isAdmin() || isOwner(userId);
    }

    match /requests/{requestId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() || isAdmin();
      allow delete: if isAdmin();
    }

    match /episodes/{episodeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /userProgress/{progressId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && progressId.matches(request.auth.uid + '_.*');
    }

    match /comments/{commentId} {
      function isValidComment(data) {
        return data.keys().hasAll(['id', 'animeId', 'episodeId', 'userId', 'userName', 'userAvatar', 'content', 'createdAt', 'likes', 'dislikes'])
          // allow optional parentId for replies
          && (data.keys().size() >= 10 && data.keys().size() <= 12)
          && isValidId(data.id)
          && data.userId == request.auth.uid
          && data.content is string && data.content.size() <= 2000
          && data.createdAt is number;
      }

      allow read: if true;
      allow create: if isSignedIn() && isValidComment(incoming());
      allow update: if isSignedIn() && (
        (isOwner(existing().userId) && isValidComment(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'updatedAt'])) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['likes', 'dislikes']))
      );
      allow delete: if isOwner(existing().userId) || isAdmin();
    }

    match /issues/{issueId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /website/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /watchProgress/{progressId} {
      function isValidProgress(data) {
        return data.userId == request.auth.uid
          && data.animeId is string && data.animeId.size() <= 128
          && data.episodeId is string && data.episodeId.size() <= 128
          && data.position is number
          && data.updatedAt is number;
      }

      allow read: if isOwner(resource.data.userId);
      allow create: if isSignedIn() && isValidProgress(incoming());
      allow update: if isOwner(existing().userId) && isValidProgress(incoming());
      allow delete: if isOwner(existing().userId);
    }

    match /broadcasts/{broadcastId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /api_keys/{keyId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
